# Copy to .env.local and fill in. NEVER commit .env.local.
# All server-only — none of these are exposed to the browser.
# Tip: `vercel env pull .env.local` fills these in automatically once they're
# set in your Vercel project.

# Neon Postgres connection string (Vercel → Storage → Neon auto-sets this,
# or copy it from the Neon console). This is the ONLY database credential —
# it lives only on the server, never in the browser.
DATABASE_URL=postgresql://user:password@your-neon-host/dbname?sslmode=require

# Google Gemini — used ONLY to screen submissions (Flash classifies each idea).
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=...
# Optional — override the moderation model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Any long random string — salts the IP hash so stored hashes aren't reversible
IP_HASH_SALT=change-me-to-a-long-random-string
